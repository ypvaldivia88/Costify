{
  "name": "costify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @costify/web dev",
    "brand:export": "node scripts/export-brand-assets.mjs",
    "dev:web": "pnpm --filter @costify/web dev",
    "dev:mobile": "pnpm --filter costify-mobile start",
    "build": "pnpm --filter @costify/web build",
    "build:web": "pnpm --filter @costify/web build",
    "start": "pnpm --filter @costify/web start",
    "lint": "pnpm --filter @costify/web lint",
    "seed:admin": "pnpm --filter @costify/web seed:admin",
    "seed:demo": "pnpm --filter @costify/web seed:demo",
    "seed:demo-multilocal": "pnpm --filter @costify/web seed:demo-multilocal",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "typecheck:shared": "pnpm --filter @costify/shared typecheck",
    "typecheck:client-data": "pnpm --filter @costify/client-data typecheck"
  },
  "devDependencies": {
    "sharp": "^0.34.3",
    "turbo": "^2.5.4",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "react-dom": "19.2.3"
    }
  }
}
