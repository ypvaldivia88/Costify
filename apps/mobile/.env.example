# --- App móvil (prefijo EXPO_PUBLIC_ requerido por Expo) ---

# URL del backend Costify (Next.js). Login, sync con MongoDB y tasas vía servidor.
# En APK/dispositivo físico usa la IP de tu PC en la red local, no localhost.
EXPO_PUBLIC_API_URL=http://192.168.1.151:3000

# Token elTOQUE TRMI. La app lo usa si el backend no está disponible.
EXPO_PUBLIC_ELTOQUE_API_TOKEN=

# --- Backend Costify (para ../Costify/.env.local, no leídas por la app móvil) ---

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.net/costify?retryWrites=true&w=majority
AUTH_SECRET=replace-with-a-long-random-secret
SUPER_ADMIN_EMAIL=admin@costify.local
SUPER_ADMIN_PASSWORD=CostifyAdmin2026!
SUPER_ADMIN_NAME=Super Admin
ELTOQUE_API_TOKEN=
