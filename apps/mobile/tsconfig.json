{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"],
      "@costify/shared/*": ["../../packages/shared/src/*"],
      "@costify/client-data/*": ["../../packages/client-data/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "src/types/env.d.ts"]
}
